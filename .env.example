# ForkFirst - local environment defaults.
# Every value here is OPTIONAL. ForkFirst runs in demo mode without any keys,
# and users can paste their own keys directly into the app instead.

# ---------------------------------------------------------------------------
# GitHub (optional)
# Used only for higher GitHub search rate limits. Use a fine-grained
# personal access token with READ-ONLY public repository access.
# Create one at: https://github.com/settings/personal-access-tokens
# ---------------------------------------------------------------------------
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# AI provider (optional)
# ForkFirst supports any OpenAI-compatible API. Use one of the keys below
# OR paste a key in the in-app Keys and providers panel.
#
# OpenAI keys:   https://platform.openai.com/api-keys
# Groq keys:     https://console.groq.com/keys
# DeepSeek keys: https://platform.deepseek.com/api_keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# Model name to use when OPENAI_API_KEY is set. Defaults to gpt-4.1-nano.
OPENAI_MODEL=gpt-4.1-nano

# ---------------------------------------------------------------------------
# Site URL (optional)
# Used for OpenGraph metadata in deployed builds.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Hosted-safety overrides (optional, advanced)
# Keep these off for public unauthenticated deployments unless you add abuse
# controls, auth, and strict request logging policies.
# Legacy OPEN_REPO_* names are still accepted for old local deployments.
# ---------------------------------------------------------------------------
FORKFIRST_ALLOW_SERVER_KEYS=false
FORKFIRST_ENABLE_SERVER_DB=false
FORKFIRST_ALLOW_PRIVATE_BASE_URLS=false

# ---------------------------------------------------------------------------
# Durable public rate limiting (recommended for hosted deployments)
# Without these, ForkFirst falls back to in-memory rate limits, which are fine
# locally but reset across serverless instances/restarts.
# Create a Redis database at https://upstash.com/ and paste the REST values.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
