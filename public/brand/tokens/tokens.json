{
  "brand": {
    "name": "ForkFirst",
    "tagline": "Idea check, before you build.",
    "description": "Find the best repo to fork — then hand the plan to your AI."
  },
  "color": {
    "brand": {
      "ink":           { "value": "#0A0B0E", "usage": "Primary surface foreground; never themed." },
      "paper":         { "value": "#F6F4EF", "usage": "Primary surface; never themed." },
      "cobalt":        { "value": "#2647F0", "usage": "Primary accent on light surfaces." },
      "cobalt-bright": { "value": "#5577FF", "usage": "Primary accent on dark surfaces." },
      "cobalt-ink":    { "value": "#0B1F8F", "usage": "Deep cobalt — text on light, hover states." },
      "cobalt-soft":   { "value": "rgba(38, 71, 240, 0.10)", "usage": "Tinted backgrounds, badges, active states." }
    },
    "semantic": {
      "light": {
        "ink": "#0A0B0E", "ink-2": "#2A2A30", "muted": "#6B6557",
        "paper": "#F6F4EF", "paper-2": "#EFEBE1", "paper-3": "#E6E1D4",
        "line": "#D6CFBA", "line-2": "#C6BFA9",
        "accent": "#2647F0", "accent-soft": "rgba(38,71,240,0.10)", "accent-ink": "#0B1F8F"
      },
      "dark": {
        "ink": "#F6F4EF", "ink-2": "#D9D4C6", "muted": "#8F8A7C",
        "paper": "#0A0B0E", "paper-2": "#14151A", "paper-3": "#1F2027",
        "line": "rgba(246,244,239,0.12)", "line-2": "rgba(246,244,239,0.20)",
        "accent": "#5577FF", "accent-soft": "rgba(85,119,255,0.16)", "accent-ink": "#B5C2FF"
      }
    },
    "signal": {
      "fork": "#19A26A",
      "ref": "#B8860B",
      "warn": "#C46A1A",
      "danger": "#C42B1A"
    }
  },
  "typography": {
    "families": {
      "display": "\"Geist\", -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "ui":      "\"Geist\", -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "mono":    "\"Geist Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
    },
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "scale": {
      "display":  { "size": "clamp(56px, 9vw, 140px)", "weight": 700, "track": "-0.05em",  "leading": 0.95 },
      "h1":       { "size": "clamp(40px, 6vw, 72px)",  "weight": 700, "track": "-0.04em",  "leading": 1.0 },
      "h2":       { "size": "clamp(28px, 4vw, 44px)",  "weight": 600, "track": "-0.035em", "leading": 1.1 },
      "h3":       { "size": "22px", "weight": 600, "track": "-0.025em", "leading": 1.2 },
      "body":     { "size": "16px", "weight": 400, "track": "-0.005em", "leading": 1.55 },
      "small":    { "size": "13.5px", "weight": 400, "track": "-0.005em", "leading": 1.5 },
      "caption":  { "size": "12px",   "weight": 500, "track": "0",       "leading": 1.4 },
      "eyebrow":  { "size": "11.5px", "weight": 500, "track": "0.14em",  "leading": 1.3, "case": "uppercase", "family": "mono" }
    }
  },
  "spacing": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "24px", "6": "32px", "7": "48px", "8": "64px", "9": "96px"
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "pill": "999px" },
  "shadow": {
    "1": "0 1px 0 rgba(10,11,14,0.04), 0 12px 32px -16px rgba(10,11,14,0.16)",
    "2": "0 1px 0 rgba(10,11,14,0.04), 0 24px 64px -24px rgba(10,11,14,0.22)"
  },
  "logo": {
    "mark": {
      "construction": "Heavy slab F with a cobalt full-stop square. Built on a 64×64 grid.",
      "geometry": [
        { "rect": [10, 6, 11, 48], "fill": "ink",    "role": "stem" },
        { "rect": [10, 6, 38, 11], "fill": "ink",    "role": "top arm" },
        { "rect": [10, 26, 26, 10], "fill": "ink",   "role": "middle arm" },
        { "rect": [48, 46, 9, 9],  "fill": "cobalt", "role": "period (the only colour note)" }
      ],
      "min-size-px": 16,
      "clearspace": "1× period block on every side"
    },
    "wordmark": {
      "construction": "\"forkfirst\" all lowercase, Geist 600, letter-spacing -0.04em, with a single cobalt bar threaded through both f-crossbars.",
      "min-size-px": 80
    }
  }
}
